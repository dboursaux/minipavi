# Minitel Environment Variables
# Copy this file to .env and fill in your values.
# .env is excluded from git and never deployed.

# Anthropic API key (required for all AI-powered services)
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY="sk-ant-api03-..."

# MiniPavi gateway WebSocket port (default: 8182)
MINIPAVI_WS_PORT=8182

# MiniPavi admin/VisuWeb port (default: 8080)
MINIPAVI_ADMIN_PORT=8080
